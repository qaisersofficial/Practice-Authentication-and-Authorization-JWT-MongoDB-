<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="text-white">
<div class="w-full h-screen bg-yellow-900 flex flex-col justify-center items-center">
    <div class="h-fit p-16 border-2 border-yellow-500 rounded-md bg-yellow-800">
        <h1 class="text-2xl font-bold text-center font-sans mb-4">Login</h1>
        <form action="/login" method="post" class="flex flex-col">
            <input class="px-4 py-2 mb-2  bg-transparent border-b-2 border-yellow-500 focus:outline-none" type="email" placeholder="Enter email" name="email" >
            <input class="px-4 py-2 mb-2  bg-transparent border-b-2 border-yellow-500 focus:outline-none" type="password" placeholder="Enter password" name="password" >
            <input type="submit" value="Login" class="px-6 py-2 mt-4 bg-yellow-700 text-white font-bold rounded-md hover:bg-yellow-500 hover:text-yellow-900 transition-all cursor-pointer">
        </form>
    </div>
</div>
</body>
</html>